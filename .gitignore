# Directories that Ren'Py changes files in.
/game/saves
/game/cache

# Compiled script files. These are important for saving, and so should
# be preserved by developer and build systems after the game has been released.
/game/**/*.rpyc
/game/**/*.rpymc

# Files Ren'Py can generate.
/game/**/*.bak
/game/**/*.new
/game/**/*.old

# Error, log, and output files.
/errors.txt
/files.txt
/image_cache.txt
/log.txt
/save_dump.txt
/traceback.txt
/combat_trace.log
/*.log

# Launcher-generated files.
/dialogue.tab
/dialogue.txt
/strings.json

# Python bytecode (tests / pure-python packages).
__pycache__/

# Machine-local Claude Code settings.
/.claude/settings.local.json

# Ren'Py MCP live bridge (dev tooling, machine-local — never commit).
/game/_mcp_bridge.rpy
/game/_mcp/

# Stray review screenshots in the project root (CLAUDE.md visual review
# loop). Game art under game/ is unaffected by this root-anchored pattern.
/*.png

# Design reference images (not game content).
/design_refs/
